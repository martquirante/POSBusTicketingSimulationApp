<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <ImageView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:src="@drawable/bg_bus"
        android:scaleType="centerCrop"
        android:contentDescription="Bus Background" />

    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/main_background"
        android:alpha="0.92"/>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardElevation="12dp"
                app:cardCornerRadius="0dp"
                android:layout_marginBottom="-10dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@color/brand_primary"
                    android:padding="20dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <ImageView
                        android:layout_width="60dp"
                        android:layout_height="60dp"
                        android:src="@drawable/bus_logo"
                        android:background="@drawable/circle_white_bg"
                        android:padding="5dp"
                        android:elevation="5dp"/>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_weight="1"
                        android:layout_marginStart="15dp">

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">
                            <ImageView
                                android:layout_width="24dp"
                                android:layout_height="24dp"
                                android:src="@drawable/ic_menu_book"
                                app:tint="#FFFFFF"
                                android:layout_marginEnd="8dp"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="CONDUCTOR\'S MENU"
                                android:textColor="#FFFFFF"
                                android:textSize="20sp"
                                android:textStyle="bold" />
                        </LinearLayout>

                        <TextView
                            android:id="@+id/tvMenuBusNo"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="BUS #: ---"
                            android:textColor="#BBDEFB"
                            android:textStyle="bold"
                            android:textSize="16sp"
                            android:layout_marginStart="32dp"/>
                    </LinearLayout>

                    <ImageButton
                        android:id="@+id/btnHelp"
                        android:layout_width="45dp"
                        android:layout_height="45dp"
                        android:background="?android:attr/selectableItemBackgroundBorderless"
                        android:src="@drawable/ic_warning"
                        android:scaleType="centerInside"
                        android:padding="8dp"
                        app:tint="#FF1744"
                        android:layout_marginEnd="5dp"
                        android:tooltipText="Request Assistance"/>

                    <ImageButton
                        android:id="@+id/btnChat"
                        android:layout_width="45dp"
                        android:layout_height="45dp"
                        android:background="?android:attr/selectableItemBackgroundBorderless"
                        android:src="@drawable/ic_chat"
                        android:scaleType="centerInside"
                        android:padding="8dp"
                        app:tint="#FFFFFF"
                        android:layout_marginEnd="5dp"
                        android:tooltipText="Chat"/>

                    <ImageButton
                        android:id="@+id/btnSettings"
                        android:layout_width="45dp"
                        android:layout_height="45dp"
                        android:background="?android:attr/selectableItemBackgroundBorderless"
                        android:src="@drawable/ic_settings"
                        android:scaleType="centerInside"
                        android:padding="8dp"
                        app:tint="#FFFFFF" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="15dp"
                android:paddingTop="30dp"
                android:paddingBottom="20dp">

                <androidx.cardview.widget.CardView
                    android:id="@+id/summaryCard"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="24dp"
                    app:cardElevation="8dp"
                    android:layout_marginBottom="25dp"
                    app:cardBackgroundColor="@color/card_background">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="24dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="TRIP SUMMARY"
                            android:textStyle="bold"
                            android:textSize="18sp"
                            android:textColor="@color/brand_primary"
                            android:layout_marginBottom="12dp"/>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:padding="12dp"
                            android:background="@drawable/rounded_red_bg"
                            android:backgroundTint="@color/input_background"
                            android:layout_marginBottom="15dp">

                            <ImageView
                                android:layout_width="22dp"
                                android:layout_height="22dp"
                                android:src="@drawable/ic_route"
                                app:tint="#D32F2F"/>
                            <TextView
                                android:id="@+id/tvCurrentLoopDisplay"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="LOADING LOOP..."
                                android:textColor="#D32F2F"
                                android:textStyle="bold"
                                android:textSize="15sp"
                                android:layout_marginStart="10dp"/>
                        </LinearLayout>

                        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="8dp" android:gravity="center_vertical">
                            <ImageView android:layout_width="18dp" android:layout_height="18dp" android:src="@drawable/ic_driver" app:tint="@color/text_secondary" android:layout_marginEnd="10dp"/>
                            <TextView android:id="@+id/tvMenuDriver" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Driver: ---" android:textColor="@color/text_primary" android:textSize="15sp" android:textStyle="bold"/>
                        </LinearLayout>
                        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="15dp" android:gravity="center_vertical">
                            <ImageView android:layout_width="18dp" android:layout_height="18dp" android:src="@drawable/ic_person_tie" app:tint="@color/text_secondary" android:layout_marginEnd="10dp"/>
                            <TextView android:id="@+id/tvMenuConductor" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Conductor: ---" android:textColor="@color/text_primary" android:textSize="15sp" android:textStyle="bold"/>
                        </LinearLayout>

                        <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#CCCCCC" android:layout_marginBottom="15dp"/>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:baselineAligned="false"
                            android:layout_marginBottom="20dp">

                            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                                <ImageView android:layout_width="26dp" android:layout_height="26dp" android:src="@drawable/ic_groups" app:tint="@color/brand_primary" android:layout_marginBottom="5dp"/>
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="REGULAR" android:textSize="11sp" android:textColor="@color/text_secondary" android:textStyle="bold"/>
                                <TextView android:id="@+id/tvRegularPax" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0" android:textSize="22sp" android:textStyle="bold" android:textColor="@color/text_primary"/>
                            </LinearLayout>

                            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                                <ImageView android:layout_width="26dp" android:layout_height="26dp" android:src="@drawable/ic_school" app:tint="#FF9800" android:layout_marginBottom="5dp"/>
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="STUDENT" android:textSize="11sp" android:textColor="@color/text_secondary" android:textStyle="bold"/>
                                <TextView android:id="@+id/tvStudentPax" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0" android:textSize="22sp" android:textStyle="bold" android:textColor="@color/text_primary"/>
                            </LinearLayout>

                            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                                <ImageView android:layout_width="26dp" android:layout_height="26dp" android:src="@drawable/ic_elderly" app:tint="#4CAF50" android:layout_marginBottom="5dp"/>
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="SENIOR" android:textSize="11sp" android:textColor="@color/text_secondary" android:textStyle="bold"/>
                                <TextView android:id="@+id/tvSeniorPax" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0" android:textSize="22sp" android:textStyle="bold" android:textColor="@color/text_primary"/>
                            </LinearLayout>
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:background="@drawable/rounded_blue_bg"
                            android:backgroundTint="@color/input_background"
                            android:padding="15dp"
                            android:gravity="center"
                            android:orientation="vertical"
                            android:layout_marginBottom="20dp">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="TOTAL PASSENGERS"
                                android:textSize="12sp"
                                android:textColor="@color/brand_primary"
                                android:textStyle="bold"/>
                            <TextView
                                android:id="@+id/tvTotalPax"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0"
                                android:textStyle="bold"
                                android:textSize="34sp"
                                android:textColor="@color/brand_primary"/>
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="15dp"
                            android:background="@color/input_background">

                            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="10dp">
                                <ImageView android:layout_width="28dp" android:layout_height="28dp" android:src="@drawable/ic_payments" app:tint="#28A745" android:layout_marginEnd="10dp"/>
                                <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="vertical">
                                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="TOTAL COLLECTED" android:textSize="12sp" android:textColor="@color/text_secondary" android:textStyle="bold"/>
                                    <TextView android:id="@+id/tvTotalCollected" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="₱0.00" android:textStyle="bold" android:textSize="24sp" android:textColor="#28A745"/>
                                </LinearLayout>
                            </LinearLayout>

                            <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#CCCCCC" android:layout_marginBottom="10dp"/>

                            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="8dp" android:gravity="center_vertical">
                                <ImageView android:layout_width="22dp" android:layout_height="22dp" android:src="@drawable/gcash_logo" android:layout_marginEnd="10dp"/>
                                <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="GCash:" android:textColor="@color/text_primary" android:textStyle="bold" android:textSize="14sp"/>
                                <TextView android:id="@+id/tvTotalGcash" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="₱0.00" android:textColor="@color/brand_primary" android:textStyle="bold" android:textSize="18sp"/>
                            </LinearLayout>

                            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical">
                                <ImageView android:layout_width="22dp" android:layout_height="22dp" android:src="@drawable/ic_peso" app:tint="#28A745" android:layout_marginEnd="10dp"/>
                                <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:text="Cash:" android:layout_weight="1" android:textColor="@color/text_primary" android:textStyle="bold" android:textSize="14sp"/>
                                <TextView android:id="@+id/tvTotalCash" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="₱0.00" android:textColor="@color/text_primary" android:textStyle="bold" android:textSize="18sp"/>
                            </LinearLayout>
                        </LinearLayout>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                 <Button
                    android:id="@+id/btnPrintReport"
                    android:layout_width="match_parent"
                    android:layout_height="65dp"
                    android:text="PRINT REPORT"
                    android:textColor="@color/text_primary"
                    android:textStyle="bold"
                    android:textSize="16sp"
                    android:layout_marginBottom="15dp"
                    app:backgroundTint="@color/brand_primary"
                    android:elevation="6dp"/>

                <Button
                    android:id="@+id/btnViewFareData"
                    android:layout_width="match_parent"
                    android:layout_height="65dp"
                    android:text="DATA FARE COLLECTED"
                    android:textColor="@color/text_primary"
                    android:textStyle="bold"
                    android:textSize="16sp"
                    android:layout_marginBottom="15dp"
                    app:backgroundTint="@color/brand_secondary"
                    android:elevation="6dp"/>

                <Button
                    android:id="@+id/btnEndTrip"
                    android:layout_width="match_parent"
                    android:layout_height="65dp"
                    android:text="CLEAR ALL DATA / NEW TRIP"
                    android:textColor="@color/text_primary"
                    android:textStyle="bold"
                    android:textSize="16sp"
                    android:layout_marginBottom="25dp"
                    app:backgroundTint="@color/footer_background"
                    android:elevation="6dp"/>

                <Button
                    android:id="@+id/btnBackMenu"
                    android:layout_width="match_parent"
                    android:layout_height="55dp"
                    android:text="BACK"
                    android:textColor="@color/text_primary"
                    android:textStyle="bold"
                    android:textSize="15sp"
                    android:layout_marginBottom="30dp"
                    app:backgroundTint="#757575"
                    android:elevation="2dp"/>

            </LinearLayout>
        </LinearLayout>
    </ScrollView>
</FrameLayout>